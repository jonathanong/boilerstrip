{
  "name": "boilerstrip",
  "version": "0.4.0",
  "description": "Learn site boilerplate selectors from a page set and convert HTML to Markdown",
  "main": "index.js",
  "types": "index.d.ts",
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "packageManager": "pnpm@11.1.2",
  "repository": {
    "type": "git",
    "url": "https://github.com/jonathanong/boilerstrip.git"
  },
  "keywords": [
    "html",
    "markdown",
    "scraping",
    "rag",
    "boilerplate"
  ],
  "files": [
    "index.js",
    "index.d.ts",
    "*.node"
  ],
  "napi": {
    "binaryName": "boilerstrip",
    "targets": [
      "x86_64-apple-darwin",
      "aarch64-apple-darwin",
      "x86_64-unknown-linux-gnu",
      "aarch64-unknown-linux-gnu",
      "x86_64-pc-windows-msvc"
    ]
  },
  "scripts": {
    "build": "napi build --platform --release",
    "build:debug": "napi build --platform",
    "test": "vitest run",
    "coverage": "vitest run --coverage",
    "prepublishOnly": "napi prepublish -t npm"
  },
  "devDependencies": {
    "@napi-rs/cli": "^3",
    "@types/node": "^25.8.0",
    "@vitest/coverage-v8": "^4",
    "typescript": "^6",
    "vitest": "^4"
  }
}
